# EasyTest — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais

# Servidor
PORT=3000
NODE_ENV=development

# Segurança do painel (senha de acesso)
ADMIN_PASSWORD=troque-esta-senha

# Google Analytics 4 (opcional)
# GA4_PROPERTY_ID=123456789
# GA4_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Meta Pixel (opcional — pode configurar por teste no painel)
# META_PIXEL_ID=

# Sessão / Cookie
SESSION_SECRET=troque-este-secret-por-algo-aleatorio
