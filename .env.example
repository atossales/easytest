# EasyTest — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais

# Servidor
PORT=3000
NODE_ENV=production

# URL pública do EasyTest (usada nos snippets e no Meta CAPI)
SITE_URL=http://pbv4szbcw8sif4lf6lrjy9pz.5.189.172.36.sslip.io

# Segurança do painel (senha de acesso)
ADMIN_PASSWORD=troque-esta-senha

# Sessão / Cookie
SESSION_SECRET=troque-este-secret-por-algo-aleatorio

# ── Agente IA (Análise de tráfego + UX) ──────────────────────────────────
# Google Gemini Flash (modelo mais barato — gemini-2.0-flash)
GEMINI_API_KEY=

# Microsoft Clarity — Data Export API
# Obter em: clarity.microsoft.com → Seu projeto → Settings → API Token
CLARITY_API_TOKEN=
# ID do projeto Clarity (está na URL: clarity.microsoft.com/projects/view/XXXXXXXX)
CLARITY_PROJECT_ID=
